rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: Is the request authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Is the request for the user's own document
    function isUser(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if isUser(userId);
    }

    match /usernames/{username} {
      allow read: if true;
      // Allow creation if the user is authenticated and they map the username to their own uid
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      // Owners may release their own reservation (used when renaming or deleting an account)
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }
  }
}
